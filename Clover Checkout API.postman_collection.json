{
  "info": {
    "_postman_id": "c1588793-fe6c-4332-8b7b-7262fa148920",
    "name": "Clover Checkout API",
    "description": "API collection for the Clover Payment Gateway integration.\n\n## Setup\n1. Login via browser at `http://localhost:3000/auth/login`\n2. Copy `connect.sid` cookie from Browser DevTools → Application → Cookies\n3. In Postman → Cookies (top right) → add domain `localhost` → paste `connect.sid` value\n\n## Endpoints\n- **Auth**: Check status, logout\n- **Checkout**: One-shot payment flow (order + line item + payment)\n- **Orders**: Create, get details, add line items\n- **Payments**: Create against order, get status",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52346146",
    "_collection_link": "https://go.postman.co/collection/52346146-c1588793-fe6c-4332-8b7b-7262fa148920?source=collection_link"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Check Auth Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/auth/status",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "auth",
                "status"
              ]
            },
            "description": "Returns whether the current session is authenticated and the connected merchant ID.\n\nExpected response:\n```json\n{ \"authenticated\": true, \"merchantId\": \"36291GPFHPV71\" }\n```"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/auth/logout",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Destroys the current session. After this, all API calls will return 401 until you login again via browser."
          },
          "response": []
        }
      ],
      "description": "OAuth2 authentication endpoints. Login happens via browser redirect — these endpoints check and manage the session."
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Full Checkout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25.00,\n  \"description\": \"Wireless Mouse\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/checkout",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "checkout"
              ]
            },
            "description": "Runs the complete 3-step payment flow in one call:\n1. Creates an order\n2. Adds a line item (product name + price)\n3. Processes the payment using a sandbox test card\n\nReturns order ID, payment ID, status, and full Clover API responses."
          },
          "response": []
        }
      ],
      "description": "One-shot endpoint that runs the complete payment flow: create order → add line item → process payment."
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/orders",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Creates an empty order on Clover. Save the returned `order.id` — you'll need it for adding line items and creating payments."
          },
          "response": []
        },
        {
          "name": "Add Line Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 15.00,\n  \"description\": \"Keyboard\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/orders/:orderId/items",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "orders",
                ":orderId",
                "items"
              ],
              "variable": [
                {
                  "key": "orderId",
                  "value": "ORDER_ID",
                  "description": "Order ID from Create Order response"
                }
              ]
            },
            "description": "Adds a product (name + price) to an existing order.\n\nReplace `:orderId` with the actual order ID from the Create Order response."
          },
          "response": []
        },
        {
          "name": "Get Order Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/orders/:orderId",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "orders",
                ":orderId"
              ],
              "variable": [
                {
                  "key": "orderId",
                  "value": "ORDER_ID",
                  "description": "Order ID to fetch"
                }
              ]
            },
            "description": "Fetches an order with its line items expanded. Use this to verify what products were added to an order."
          },
          "response": []
        }
      ],
      "description": "Manage orders independently. Use these to test the step-by-step flow instead of the one-shot checkout."
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORDER_ID\",\n  \"amount\": 15.00\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/payments",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "payments"
              ]
            },
            "description": "Creates a payment against an existing order using a sandbox test card (Visa 4111...1111).\n\nReplace `ORDER_ID` in the body with the actual order ID."
          },
          "response": []
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/payments/:paymentId",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "payments",
                ":paymentId"
              ],
              "variable": [
                {
                  "key": "paymentId",
                  "value": "PAYMENT_ID",
                  "description": "Payment ID from Create Payment or Checkout response"
                }
              ]
            },
            "description": "Fetches the current status and details of a payment. Use this to verify whether a payment was successful."
          },
          "response": []
        }
      ],
      "description": "Create and check payment status. Payments must be linked to an existing order."
    }
  ]
}